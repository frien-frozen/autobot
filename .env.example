# From @BotFather (enable Business / Secretary Mode on the bot)
BOT_TOKEN=

# Your numeric Telegram user id (message @userinfobot to get it)
OWNER_USER_ID=

# Google AI Studio / Gemini API key
GEMINI_API_KEY=

# Model name (subscription-friendly defaults)
GEMINI_MODEL=gemini-3.5-flash

# polling = local test (default); webhook = Render
MODE=polling

# Public HTTPS URL of this service, no trailing slash (webhook mode only)
# On Render this is auto-filled from RENDER_EXTERNAL_URL if left empty
WEBHOOK_URL=

# Optional: secret path segment so strangers cannot POST to your webhook
WEBHOOK_SECRET=change-me-to-a-long-random-string

# Render sets PORT automatically; local default is 8080
PORT=8080

# SQLite folder — on Render mount a Disk at /data and set DATA_DIR=/data
DATA_DIR=./data

# How many recent messages to send to Gemini per reply
HISTORY_LIMIT=40

# Minutes to pause auto-reply in a chat after you answer manually
OWNER_PAUSE_MINUTES=30
