# From @BotFather (enable Business / Secretary Mode on the bot)
BOT_TOKEN=

# Your numeric Telegram user id (Business account / primary)
OWNER_USER_ID=

# Other accounts that are also you (comma-separated)
OWNER_IDS=

# Google AI Studio / Gemini API key
GEMINI_API_KEY=

# Model name
GEMINI_MODEL=gemini-3.5-flash

# polling = local test; webhook = Render
MODE=polling

# Asia/Tashkent by default
TIMEZONE=Asia/Tashkent

WEBHOOK_URL=
WEBHOOK_SECRET=change-me-to-a-long-random-string
PORT=8080
DATA_DIR=./data
HISTORY_LIMIT=40
OWNER_PAUSE_MINUTES=30
SCHEDULER_POLL_SECONDS=20
REMINDER_FOLLOWUP_HOURS=3
